{
  "name": "invoice-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "parse": "tsx src/index.ts",
    "parse:sample": "tsx src/index.ts sample-podklad.txt"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.19.0",
    "vitest": "^4.1.2"
  }
}
