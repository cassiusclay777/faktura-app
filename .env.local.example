# API klíče – načtou se z tohoto souboru, z `.env` ve stejné složce,
# nebo z `invoice-assistant/.env` (viz src/lib/loadEnv.ts).

# Přepis fotky přes Gemini (volitelné, pokud nahráváš jen .txt, nepotřebuješ)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Ollama – jen pokud v UI vybereš přepis „Ollama“
# OLLAMA_VISION_MODEL=llava
# OLLAMA_BASE_URL=http://127.0.0.1:11434
