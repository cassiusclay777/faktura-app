# Zkopíruj jako `.env` nebo `.env.local` v kořeni `faktura-app`.
# OpenRouter/Ollama/Gemini berou klíče odtud (viz src/lib/loadEnv.ts).

# --- OpenRouter (přepis fotky v UI + korekce názvů přes „OpenRouter“) ---
OPENROUTER_API_KEY=
# OPENROUTER_VISION_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_API_BASE=https://openrouter.ai/api

# --- Gemini (volitelně jen pro korekci názvů přes „Gemini“) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Legacy fallback (dočasně kvůli kompatibilitě) ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-reasoner
# DEEPSEEK_API_BASE=https://api.deepseek.com

# --- Ollama (jen pokud v UI vybereš přepis „Ollama“) ---
# OLLAMA_VISION_MODEL=llava
# OLLAMA_BASE_URL=http://127.0.0.1:11434
