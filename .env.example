# Invoice Assistant – konfigurace API klíčů
# Zkopíruj tento soubor jako .env a doplň své klíče.

# ============================================
# Gemini (Google AI)
# ============================================
# Získej na https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Volitelně: model pro OCR a korekci názvů (výchozí gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ============================================
# DeepSeek (AI model pro korekci názvů)
# ============================================
# Získej na https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Volitelně: model pro korekci (výchozí deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat
# Volitelně: vlastní endpoint (výchozí https://api.deepseek.com)
# DEEPSEEK_API_BASE=https://api.deepseek.com

# ============================================
# DeepSeek Vision OCR (pro přepis obrázků)
# ============================================
# DeepSeek oficiálně nepodporuje obrázky, proto použij OpenAI‑kompatibilní endpoint
# Např. OpenRouter, Together AI, nebo jiný poskytovatel s vision modelem
DEEPSEEK_VISION_API_BASE=https://openrouter.ai/api/v1
# Klíč pro vision endpoint (OpenRouter, OpenAI, nebo jiný)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Případně lze použít OPENAI_API_KEY nebo DEEPSEEK_VISION_API_KEY
# OPENAI_API_KEY=your_openai_api_key_here
# DEEPSEEK_VISION_API_KEY=your_vision_api_key_here
# Volitelně: model pro vision (výchozí gpt-4o-mini)
# DEEPSEEK_VISION_MODEL=gpt-4o-mini

# ============================================
# Webové vyhledávání pro korekci názvů (DeepSeek)
# ============================================
# Pro DeepSeek + web vyhledávání (Perplexity nebo Tavily)
# PERPLEXITY_API_KEY=your_perplexity_api_key_here
# TAVILY_API_KEY=your_tavily_api_key_here
# Volitelně: zvol preferovaného poskytovatele (perplexity|tavily)
# DEEPSEEK_WEB_SEARCH_PROVIDER=perplexity

# ============================================
# Ollama (lokální AI)
# ============================================
# Vision model pro OCR (např. llava, moondream, llava-phi3)
OLLAMA_VISION_MODEL=llava
# Volitelně: vlastní URL (výchozí http://127.0.0.1:11434)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ============================================
# Obecné nastavení
# ============================================
# Výchozí provider pro OCR (gemini|ollama|deepseek)
# VISION_PROVIDER=gemini

# ============================================
# ARES (vyhledávání firem podle IČO)
# ============================================
# Nepotřebuje API klíč – používá veřejné API ARES
# (žádné proměnné)

# ============================================
# Další volitelné
# ============================================
# DEBUG=1
# NODE_ENV=development
