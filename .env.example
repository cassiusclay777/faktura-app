# Zkopíruj jako `.env` nebo `.env.local` v kořeni `faktura-app`.
# Gemini i OpenRouter berou klíče odtud (viz src/lib/loadEnv.ts).

# --- Gemini (přepis fotky/PDF, korekce názvů přes „Gemini“) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- OpenRouter (korekce názvů přes „OpenRouter“ v UI) ---
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
# OPENROUTER_API_BASE=https://openrouter.ai/api

# --- Legacy fallback (dočasně kvůli kompatibilitě) ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com

# --- Ollama (jen pokud v UI vybereš přepis „Ollama“) ---
# OLLAMA_VISION_MODEL=llava
# OLLAMA_BASE_URL=http://127.0.0.1:11434
