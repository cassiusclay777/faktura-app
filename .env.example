# Zkopíruj jako `.env` nebo `.env.local` v kořeni `faktura-app`.
# Gemini i DeepSeek berou klíče odtud (viz src/lib/loadEnv.ts).

# --- Gemini (přepis fotky/PDF, korekce názvů přes „Gemini“) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- DeepSeek (korekce názvů přes „DeepSeek“ v UI) ---
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com
# Volitelně pro „Vyhledávat na webu“ u korekce DeepSeek (lepší než výchozí DuckDuckGo):
# TAVILY_API_KEY=

# --- Ollama (jen pokud v UI vybereš přepis „Ollama“) ---
# OLLAMA_VISION_MODEL=llava
# OLLAMA_BASE_URL=http://127.0.0.1:11434
